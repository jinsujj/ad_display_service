# =============================================================================
# AdSignage docker compose 환경 변수
#
# 사용:
#   cp .env.example .env
#   # 아래 값 실제로 채우고
#   docker compose up -d
# =============================================================================

# ----- 필수 ------------------------------------------------------------------
# JWT 서명 비밀키. HS256 권장 길이(>= 32바이트). 한 줄로 두는 게 편하다.
#   openssl rand -hex 64
JWT_SECRET=change-me-generate-with-openssl-rand-hex-64

# ----- 빌드/배포 ------------------------------------------------------------
# 빌드 타임에 web 번들에 인라인되는 백엔드 base URL.
#   - 동일 도메인(nginx 합치는 구성):  빈 문자열  (상대경로)
#   - 분리 도메인:                    https://stream-backend.owl-dev.me
NEXT_PUBLIC_API_BASE_URL=

# Spring 일일 카운터의 자정 기준 타임존. 프론트 dailyCount 의 로컬 자정과
# 일치해야 하므로 운영 위치와 같게.
DAILY_COUNT_ZONE_ID=Asia/Seoul

# ----- 이미지 (ghcr 또는 다른 레지스트리에서 pull 할 때 override) -----------
# CI 가 푸시하는 태그를 쓰려면 :sha-<short> 또는 :main 으로 핀.
# BACKEND_IMAGE=ghcr.io/jinsujj/adsignage-backend:main
# WEB_IMAGE=ghcr.io/jinsujj/adsignage-web:main

# ----- 호스트 포트 ----------------------------------------------------------
# nginx stream-backend / stream 이 각각 8082 / 3002 로 프록시하도록 설정되어
# 있으므로 docker 도 그 포트로 publish 하는 게 default. 다른 포트로 옮길 때만
# 여기 override.
BACKEND_HOST_PORT=8082
WEB_HOST_PORT=3002

# ----- PostgreSQL (외부 컨테이너 활용) -------------------------------------
# 같은 호스트의 postgres 컨테이너(owl-blog-network 에 attached) 를 backend 가
# 컨테이너 이름으로 호출. owldev DB 안에 별도 schema(`adsignage`) 로 격리.
POSTGRES_USER=jinsu
POSTGRES_PASSWORD=
# postgres 컨테이너가 붙어 있는 docker network 이름.
POSTGRES_NETWORK=owl-blog-network
# 필요 시 datasource URL 직접 override (host/port/db/schema).
# SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/owldev?currentSchema=adsignage

# ----- 선택 ------------------------------------------------------------------
# Spring profile (application-prod.yml 등을 추가하면 사용).
SPRING_PROFILES_ACTIVE=prod
