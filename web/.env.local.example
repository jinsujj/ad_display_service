# Public base URL for the Spring Boot REST API.
#
# - In local dev (`npm run dev`) point at the laptop or Ubuntu host:
#       NEXT_PUBLIC_API_BASE_URL=http://192.168.0.24:8080
# - In production (admin served from stream.owl-dev.me behind nginx) leave
#   this blank so requests are made same-origin (the nginx config in
#   deploy/nginx/stream.owl-dev.me.conf already proxies /api/* to Spring).
NEXT_PUBLIC_API_BASE_URL=
